# Backend
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=

# AI Recipe Import
# Set AI_PROVIDER to: anthropic | openai | google
AI_PROVIDER=anthropic

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Gemini (https://aistudio.google.com)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith observability (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shop-n-cook

# ---------------------------------------------------------------------------
# Variables below map to Coolify magic variables in compose.yml.
# In production Coolify auto-generates them; locally set them here.
# ---------------------------------------------------------------------------

# Postgres credentials (Coolify: SERVICE_USER_DB / SERVICE_PASSWORD_DB)
SERVICE_USER_DB=postgres
SERVICE_PASSWORD_DB=changethis

# JWT secret key (Coolify: SERVICE_BASE64_64_BACKEND)
SERVICE_BASE64_64_BACKEND=changethis

# Frontend public URL — used by backend for CORS and email links
# (Coolify: SERVICE_URL_FRONTEND)
SERVICE_URL_FRONTEND=http://localhost:5173

# Backend public URL — baked into the frontend bundle at build time
# (Coolify: SERVICE_URL_BACKEND)
SERVICE_URL_BACKEND=http://localhost:8000

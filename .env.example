# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In production, set this to the frontend URL, e.g.:
# FRONTEND_HOST=https://app.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Shop n Cook"

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Frontend — URL of the backend API, used at build time by Vite
# In production, set this to the backend URL, e.g.:
# VITE_API_URL=https://api.example.com
API_URL=http://localhost:8000

# Frontend — project name displayed in the browser tab and UI
VITE_PROJECT_NAME="Shop n Cook"

# AI Recipe Import
# Set AI_PROVIDER to: anthropic | openai | google
AI_PROVIDER=anthropic

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Gemini (https://aistudio.google.com)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith observability (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shop-n-cook
